use "vek/ansi"
use "vek/stdio"
use "std/os"

const errorExitCode = 1

fn printErrorMessage(msg: str) {
	stdio::Print(ansi::Red)
	stdio::Print("error: ")
	stdio::Println(msg)
	stdio::Print(ansi::Reset)
}

fn throwError(msg: str) {
	printErrorMessage(msg)
	stdio::Flush()
	os::Exit(errorExitCode)
}