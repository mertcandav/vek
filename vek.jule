use "std/math/bits"

// Generates error when UintSize is 32.
// This is mandatory to make sure uint is a 64-bit integer.
// Because we cast it to isa::Index sometimes, or vice versa.
// Bitsize must be same for correctness.
const _ = 1 / (bits::UintSize - 32)

// Version of vek.
const Version = "vek0.0.1"