use "vek/isa"

// Data types.
const (
	TypeIN = iota // Integer.
	TypeFL        // Floating-point.
)

// Data of a vek value.
enum Data: type {
	&isa::Int,  // Integer.
	isa::Float, // Floating-point.
}

// A vek value.
struct Value {
	Type: int
	Data: Data
}