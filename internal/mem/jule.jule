struct Smartptr[T] {
	Ptr: *T
	Ref: *uint
}

struct DynamicTypeMeta {
	Dealloc: *unsafe
	Hash:    *unsafe
	Eq:      *unsafe
	ToStr:   *unsafe
}

struct DynamicType {
	Data: Smartptr[uintptr]
	Type: *DynamicTypeMeta
}