// A registry of pre-defined external functions provided by the VM.
// All functions must be called with ECALL instruction.
let mut funcmap = mem::FuncMap{}

// Outputs the top value of the stack to the standard output (stdout) stream.
// This function retrieves the most recently pushed element and displays its
// string representation in the console.
fn _EXTERN_PRINT(mut &vm: *VM): (err: str) {
	vm.stackRead(isa::STCK_OFF).Print()
	_RET(vm) // RET

	ret _NoError
}