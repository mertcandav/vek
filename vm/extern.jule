use "vek"
use "vek/isa"
use "vek/vm/mem"
use "std/math"

// External Functions
//
// This mechanism utilizes the external function
// logic permitted by the vek ISA specification via the ECALL instruction.
// By default, every vek VM instance integrates these predefined
// external functions into the program's execution environment,
// ensuring a consistent set of standardized routines is
// available for the binary to invoke.

// The instruction map serves as a dispatch table where each
// ECALL index acts as a direct index. This mechanism maps the
// index to its corresponding externnal function execution routine,
// enabling the virtual machine to resolve and trigger the specific
// functional logic required for that extern call.
//
// Initialized by init.
let mut externmap: [...]insfunc = [
	_EXTERN_PRINT,
]

const (
	_Ln2  = 0.693147180559945309417232121458176568075500134360255254120680009 // https://oeis.org/A002162
	_Ln10 = 2.30258509299404568401799145468436420760110148862877297603332790  // https://oeis.org/A002392
)

let mut _value_Pi = newFL(3.14159265358979323846264338327950288419716939937510582097494459)     // https://oeis.org/A000796
let mut _value_Phi = newFL(1.61803398874989484820458683436563811772030917980576286213544862)    // https://oeis.org/A001622
let mut _value_Euler = newFL(0.577215664901532860606512090082402431042159335939923598805767234) // https://oeis.org/A001620

