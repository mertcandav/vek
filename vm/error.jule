use "vek/isa"

// Special error values.
const (
	// Error message indicating success.
	_NoError = ""

	// Error is cached on the vm.err field.
	_ErrorCached = "_ErrorCached"
)

// A virtual machine error.
struct Error {
	Opcode: isa::Opcode // The opcode.
	PC:     isa::PC     // The PC of the opcode.
	Error:  str         // The problem.
}