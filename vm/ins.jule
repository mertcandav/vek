	vm.pc++                // POW
	dst := decodeIndex(vm) // DESTINATION
	val := decodeIndex(vm) // VALUE

	// POW dst,val
	mut dstv := vm.stackRead(dst)
	valv := vm.stackRead(val)
	dstv.POW(valv)

	ret _NoError
}

fn _POWIN(mut &vm: *VM): (err: str) {
	vm.pc++                  // POWIN
	dst := decodeIndex(vm)   // DESTINATION
	mut _in := decodeInt(vm) // Integer.

	// POWIN dst,_in
	mut dstv := vm.stackRead(dst)
	dstv.POWIN(_in)

	ret _NoError
}

fn _POWFL(mut &vm: *VM): (err: str) {
	vm.pc++                // POWFL
	dst := decodeIndex(vm) // DESTINATION
	fl := decodeFloat(vm)  // Float.

	// POWFL dst,fl
	mut dstv := vm.stackRead(dst)
	dstv.POWFL(fl)

	ret _NoError
}

// Decodes integer.
fn decodeInt(mut &vm: *VM): &isa::Int {
	datalen := decodeIndex(vm)
	sign := vm.bin[vm.pc]
	vm.pc++ // sign-byte
	enc := vm.bin[vm.pc : vm.pc+isa::PC(datalen)]
	vm.pc += isa::PC(datalen)
	mut _in := new(isa::Int)
	_in.SetBytes(enc)
	if sign == 1 {
		_in.Neg(&*_in)
	}
	ret _in
}

// Decodes floating-point.
fn decodeFloat(mut &vm: *VM): isa::Float {
	let mut b: u64
	b |= u64(vm.bin[vm.pc]) << 56
	vm.pc++
	b |= u64(vm.bin[vm.pc]) << 48
	vm.pc++
	b |= u64(vm.bin[vm.pc]) << 40
	vm.pc++
	b |= u64(vm.bin[vm.pc]) << 32
	vm.pc++
	b |= u64(vm.bin[vm.pc]) << 24
	vm.pc++
	b |= u64(vm.bin[vm.pc]) << 16
	vm.pc++
	b |= u64(vm.bin[vm.pc]) << 8
	vm.pc++
	b |= u64(vm.bin[vm.pc])
	vm.pc++
	ret math::F64frombits(b)
}

// Decodes index.
fn decodeIndex(mut &vm: *VM): (idx: isa::Index) {
	idx |= isa::Index(vm.bin[vm.pc]) << 56
	vm.pc++
	idx |= isa::Index(vm.bin[vm.pc]) << 48
	vm.pc++
	idx |= isa::Index(vm.bin[vm.pc]) << 40
	vm.pc++
	idx |= isa::Index(vm.bin[vm.pc]) << 32
	vm.pc++
	idx |= isa::Index(vm.bin[vm.pc]) << 24
	vm.pc++
	idx |= isa::Index(vm.bin[vm.pc]) << 16
	vm.pc++
	idx |= isa::Index(vm.bin[vm.pc]) << 8
	vm.pc++
	idx |= isa::Index(vm.bin[vm.pc])
	vm.pc++
	ret
}