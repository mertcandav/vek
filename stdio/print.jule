use "vek/ioutil"
use "std/os"

let mut stdout = ioutil::Writer.New(os::Stdout())

#disable nilptr
fn Print(s: str) {
	stdout.WriteStr(s) else {}
}

#disable nilptr
fn Println(s: str) {
	Print(s)
	stdout.WriteByte('\n') else {}
}

#disable nilptr
fn Flush() {
	stdout.Flush() else {}
}